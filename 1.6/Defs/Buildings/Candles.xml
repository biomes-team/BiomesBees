<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>BMT_BeeswaxCandle</defName>
    <label>candle</label>
    <description>A candle or candles for light and soft warmth. People need light to move and work at full speed. Can be automatically refueled with wax. Produces marginally less light and heat than torches.</description>
    <graphicData>
      <texPath>BMT_Bees/Things/Building/Candles</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <drawRotated>false</drawRotated>
	  <drawSize>2.5</drawSize>
      <damageData>
        <rect>(0.35,0.35,0.3,0.3)</rect>
      </damageData>
    </graphicData>
    <altitudeLayer>BuildingOnTop</altitudeLayer>
    <uiIconPath>BMT_Bees/Things/Building/Candles/CandlesIcon</uiIconPath>
    <uiIconScale>2.5</uiIconScale>
    <tickerType>Normal</tickerType>
    <statBases>
      <MaxHitPoints>55</MaxHitPoints>
      <WorkToBuild>100</WorkToBuild>
      <Flammability>0</Flammability>
      <MeditationFocusStrength>0.0</MeditationFocusStrength>
    </statBases>
    <building>
         <isEdifice>false</isEdifice>
    </building>
    <constructEffect>ConstructWood</constructEffect>
    <clearBuildingArea>false</clearBuildingArea>
    <costList>
      <BMT_Waxblock>10</BMT_Waxblock>
    </costList>
    <soundImpactDefault>BulletImpact_Ground</soundImpactDefault>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <resourcesFractionWhenDeconstructed>0</resourcesFractionWhenDeconstructed>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <placeWorkers>
      <li>PlaceWorker_Heater</li>
      <li>PlaceWorker_MeditationOffsetBuildingsNear</li>
      <li>PlaceWorker_GlowRadius</li>
    </placeWorkers>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <comps Inherit="False">
      <li Class="CompProperties_Styleable" />
      <li Class="CompProperties_Glower">
        <glowRadius>7</glowRadius>
        <glowColor>(184,136,83,0)</glowColor>
      </li>
      <li Class="CompProperties_HeatPusher">
        <compClass>CompHeatPusherPowered</compClass>
        <heatPerSecond>2.5</heatPerSecond>
        <heatPushMaxTemperature>23</heatPushMaxTemperature>
      </li>
      <li Class="CompProperties_Refuelable">
        <fuelConsumptionRate>1.0</fuelConsumptionRate>
        <fuelCapacity>20.0</fuelCapacity>
        <fuelConsumptionPerTickInRain>0.0006</fuelConsumptionPerTickInRain>
        <fuelFilter>
          <thingDefs>
            <li>BMT_Waxblock</li>
          </thingDefs>
        </fuelFilter>
        <initialFuelPercent>1</initialFuelPercent>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <functionsInVacuum>false</functionsInVacuum>
      </li>
      <li Class="CompProperties_MeditationFocus">
        <statDef>MeditationFocusStrength</statDef>
        <focusTypes>
          <li>Flame</li>
        </focusTypes>
        <offsets>
          <li Class="FocusStrengthOffset_Lit">
            <offset>0.1</offset>
          </li>
          <li Class="FocusStrengthOffset_BuildingDefsLit">
            <defs>
              <li>Campfire</li>
              <li>TorchLamp</li>
              <li>TorchWallLamp</li>
              <li MayRequire="Ludeon.RimWorld.Royalty">Brazier</li>
              <li MayRequire="Ludeon.RimWorld.Royalty,Ludeon.RimWorld.Ideology">DarklightBrazier</li>
              <li MayRequire="Ludeon.RimWorld.Ideology">Darktorch</li>
              <li MayRequire="Ludeon.RimWorld.Ideology">DarktorchFungus</li>
            </defs>
            <offsetPerBuilding>0.01</offsetPerBuilding>
            <radius>9.9</radius>
            <maxBuildings>8</maxBuildings>
            <explanationKey>MeditationFocusPerFlame</explanationKey>
            <explanationKeyAbstract>MeditationFocusPerFlameAbstract</explanationKeyAbstract>
            <drawRingRadius>false</drawRingRadius>
          </li>
        </offsets>
      </li>
    </comps>
    <designationCategory>Furniture</designationCategory>
    <uiOrder>2800</uiOrder>
    <designationHotKey>Misc10</designationHotKey>
  </ThingDef>
  
</Defs>