<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <ThingDef ParentName="TreeBase">
        <defName>BMT_WildBeehive</defName>
        <label>wild beehive</label>
        <description>A wild beehive built within the stump of a tree. A queen bee can be taken from within, but an angry swarm will emerge once harvested.</description>
        <graphicData>
            <texPath>BMT_Bees/Things/Building/NaturalHive/NaturalHive</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <!--<shadowData>
                <volume>(0.15, 0.3, 0.15)</volume>
                <offset>(0,0,-0.38)</offset>
            </shadowData>-->
        </graphicData>
		<thingClass>BMT.BiomesPlant</thingClass>
        <ingestible>
            <preferability>NeverForNutrition</preferability>
        </ingestible>
		<plant Inherit="False" >
			<growMinGlow>0</growMinGlow>
			<growOptimalGlow>0</growOptimalGlow>
			<interferesWithRoof>false</interferesWithRoof>
			<pollution>Any</pollution>
			<topWindExposure>0.0</topWindExposure>
			<minGrowthTemperature>0</minGrowthTemperature>		
			<maxGrowthTemperature>40</maxGrowthTemperature>
			<mustBeWildToSow>true</mustBeWildToSow>
			<harvestWork>200</harvestWork>
			<harvestYield>1</harvestYield>
			<harvestTag>Standard</harvestTag>
			<harvestAfterGrowth>0.1</harvestAfterGrowth>
			<harvestedThingDef>BMT_QueenBee</harvestedThingDef>
			<fertilitySensitivity>0</fertilitySensitivity>
			<interferesWithRoof>false</interferesWithRoof>
			<growDays>10</growDays>
			<soundHarvesting>Harvest_Tree</soundHarvesting>
			<soundHarvestFinish>Harvest_Tree_Finish</soundHarvestFinish>
		</plant>
        <blockWind>false</blockWind>
		<receivesSignals>true</receivesSignals>
		<comps>
			<li Class="CompProperties_CanBeDormant">
				<startsDormant>false</startsDormant>
				<canWakeUpFogged>false</canWakeUpFogged>
			</li>
			<!-- <li Class="BiomesCore.CompProperties_CantSpawnOnTempMap"/> -->
			<li Class="CompProperties_SelfhealHitpoints">
				<ticksPerHeal>6000</ticksPerHeal>
			</li>
	  <li Class="BiomesBees.CompProperties_BeesHive">
		<!-- statDef factor -->
		<!-- <failChanceStatDef>BMT_HoneyHarvestFailChance</failChanceStatDef> -->
		<!-- ultratech stuff -->
		<flowerlessProduction>true</flowerlessProduction>
		<honeyProductionWithoutFlowers>0.1</honeyProductionWithoutFlowers>
		<!-- search radius. float -->
		<flowerRadius>10.5</flowerRadius>
		<!-- Honey per flower -->
		<honeyPerFlower>0.01</honeyPerFlower>
		<!-- apiary tick freq. After apiary_tick honey is produced. Formula: flowers_in_radius * honeyPerFlower -->
		<honeyTick>6000</honeyTick>
		<!-- Product. Any ThingDef -->
		<productDef>BMT_Honeycomb</productDef>
		<!-- Amount when auto-work can be triggered. Job can spawn honey or angry bees -->
		<bestHarvestAmount>45</bestHarvestAmount>
		<!-- Max honey (or human meat) in apiary -->
		<honeyLimit>50</honeyLimit>
		<!-- Uniqe tag. Used for saves. Each CompProperties_BeesHive in single def req. uniqe uniqueTag -->
		<uniqueTag>HoneyMaker5000</uniqueTag>

		<!-- Any enemy faction -->
		<angryBeeFaction>BMT_AngryWildBees</angryBeeFaction>
		<!-- Any PawnkindDef -->
		<angryBeesDefs>
		  <li>BMT_Bees</li>
		</angryBeesDefs>

		<!-- Whitelisted ThingDefs. First check -->
		<whitelist>
		  <li>Corpse_Human</li>
		</whitelist>
		<!-- Blacklisted ThingDefs. Second check -->
		<blacklist>
		  <li>Corpse_Mech_CentipedeGunner</li>
		</blacklist>
		<!-- Third check. Always requred -->
		<!-- Plants tags: Food, Health, Beauty, Misc  -->
		<plantPurpose>
		  <li>Beauty</li>
		</plantPurpose>

		<!-- xp per work tick. Work tick currently =720 -->
		<xpPerTick>1</xpPerTick>
		<!-- Harvest job fail chance. Fail summon angry bees. Formula: basicFailChance * harvester_animals_skill_level -->
		<basicFailChance>0.1</basicFailChance>
		<!-- Harvest never fails if skill >= safeHarvestLevel -->
		<safeHarvestLevel>16</safeHarvestLevel>

		<!-- same as hive spawner -->
		<pawnSpawnRadius>2</pawnSpawnRadius>
		<defendRadius>7</defendRadius>
		<wanderRadius>6</wanderRadius>
		<!-- Sound to play when a new pawn is created. -->
		<spawnSound>Hive_Spawn</spawnSound>
	  </li>
		</comps>
        <modExtensions>
            <li Class="BiomesCore.DefModExtensions.AdditionalHarvestDrops">
                <defs>
                    <li>BMT_Honeycomb</li>
                </defs>
                <yields>
                    <li>10</li>
                </yields>
            </li>
        </modExtensions>
    </ThingDef>

</Defs>