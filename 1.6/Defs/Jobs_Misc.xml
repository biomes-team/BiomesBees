<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <WorkGiverDef>
	<defName>BMT_HarvestHoneyFromHive</defName>
	<label>harvest honey</label>
	<giverClass>BiomesBees.WorkGiver_HarvestHoney</giverClass>
	<workType>Handling</workType>
	<verb>harvset</verb>
	<gerund>harvesting</gerund>
	<priorityInType>20</priorityInType>
	<requiredCapacities>
	  <li>Manipulation</li>
	</requiredCapacities>
  </WorkGiverDef>

  <JobDef>
	<defName>BMT_HarvestHoneyFromHive</defName>
	<driverClass>BiomesBees.JobDriver_HarvestHoney</driverClass>
	<reportString>harvesting honey.</reportString>
	<allowOpportunisticPrefix>true</allowOpportunisticPrefix>
  </JobDef>


